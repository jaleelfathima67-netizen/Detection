{
  "name": "fakebuster-root",
  "version": "1.0.0",
  "description": "Root scripts for Fake Buster project",
  "scripts": {
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"npm run backend\" \"npm run frontend\"",
    "backend": "python backend/manage.py runserver 8000",
    "frontend": "npm run dev --prefix frontend",
    "install-all": "npm install && npm install --prefix frontend",
    "clean": "taskkill /f /im node.exe /im python.exe /t || echo Already clean",
    "train": "python backend/train_model.py"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
